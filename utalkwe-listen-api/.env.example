# Server
NODE_ENV=production
PORT=3001
SERVER_URL=https://your-railway-app.up.railway.app

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vapi
VAPI_WEBHOOK_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Subscription price ID for Unlimited tier ($29.99 / month)
STRIPE_PRICE_UNLIMITED=

# Quick Call one-time packs ($0.99 per minute) — each Stripe Payment Link
# MUST include metadata pack_minutes=<value> so the webhook credits the right amount.
STRIPE_PAYMENT_LINK_QUICK_10=     # $9.90  / 10 min — metadata pack_minutes=10
STRIPE_PAYMENT_LINK_QUICK_30=     # $29.70 / 30 min — metadata pack_minutes=30
STRIPE_PAYMENT_LINK_QUICK_60=     # $59.40 / 60 min — metadata pack_minutes=60

# Unlimited monthly subscription ($29.99 / month)
STRIPE_PAYMENT_LINK_UNLIMITED=

# Free Tier
FREE_MINUTES_GRANT=10  # New callers start with this many free minutes (also default in DB schema)
