# Server
NODE_ENV=production
PORT=3001
SERVER_URL=https://your-railway-app.up.railway.app

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vapi
VAPI_WEBHOOK_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_VIP=
# Subscription Payment Links (from Stripe Dashboard → Payment Links)
STRIPE_PAYMENT_LINK_BASIC=
STRIPE_PAYMENT_LINK_PREMIUM=
STRIPE_PAYMENT_LINK_VIP=
# One-time Minute Pack Payment Links — each must include metadata pack_minutes=25/90/200/400
STRIPE_PAYMENT_LINK_PACK_STARTER=   # $5  / 25 min  — metadata pack_minutes=25
STRIPE_PAYMENT_LINK_PACK_PLUS=      # $15 / 90 min  — metadata pack_minutes=90
STRIPE_PAYMENT_LINK_PACK_PRO=       # $30 / 200 min — metadata pack_minutes=200
STRIPE_PAYMENT_LINK_PACK_VIP=       # $50 / 400 min — metadata pack_minutes=400

# Free Tier (deprecated — kept for reference; no longer enforced by canAccessCall)
# FREE_CALLS_PER_MONTH=3
# FREE_CALL_MAX_MINUTES=10
FREE_MINUTES_GRANT=5  # New callers start with this many minutes (default in DB schema)
